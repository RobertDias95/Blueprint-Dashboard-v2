# Vitest auto-loads this file under mode=test (Vite's loadEnv default).
# Placeholder values satisfy src/lib/supabase.ts's import-time check so
# the test suite can run without a real .env.local. Tests mock all
# Supabase usage (vi.mock('../lib/supabase' ...) or hook-level mocks),
# so these stubs never reach the network.
VITE_SUPABASE_URL=http://test.local
VITE_SUPABASE_ANON_KEY=test-anon-key-not-real
